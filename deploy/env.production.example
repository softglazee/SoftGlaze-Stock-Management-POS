# SoftGlaze API — PRODUCTION env. Copy to apps/server/.env on the VPS and fill in.
# NEVER commit the real .env.  Generate each secret with:  openssl rand -hex 32

DATABASE_URL="postgresql://softglaze:STRONG_DB_PASSWORD@localhost:5432/softglaze?schema=public"
PORT=4000
NODE_ENV=production

JWT_SECRET="PASTE_openssl_rand_hex_32_HERE"
JWT_REFRESH_SECRET="PASTE_A_DIFFERENT_openssl_rand_hex_32_HERE"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# Your public site (used for CORS). With nginx serving the web app on the same
# domain this is your https URL:
CORS_ORIGIN="https://stock.YOURSHOP.com"

# Where uploaded product/logo images are stored on the server (absolute path so they
# survive redeploys — keep it OUTSIDE the git checkout):
UPLOAD_DIR="/var/www/softglaze-uploads"

# (The daily reminder sweep time is set in the app: Settings → not an env var.)
# (nginx serves the web app, so SERVE_WEB is left unset here.)
