// SoftGlaze — Complete Database Schema
// Covers: users/roles, categories, units, products+images, customers, vendors,
// purchases, sales/POS, returns, payments, expenses, stock ledger, audit log, settings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // For pure-offline desktop you can switch to "sqlite" (see docs/07-DEPLOYMENT.md)
  url      = env("DATABASE_URL")
}

// ─────────────────────────── AUTH & USERS ───────────────────────────

enum Role {
  SUPER_ADMIN // global owner: settings, business type, integrations, everything
  ADMIN      // everything except super-admin global settings
  MANAGER    // everything except user management & settings
  CASHIER    // POS, customers, view products
  ACCOUNTANT // payments, expenses, reports, ledgers
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String?
  passwordHash String
  role         Role      @default(CASHIER)
  isActive     Boolean   @default(true)
  refreshToken String?   // hashed refresh token
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sales          Sale[]
  purchases      Purchase[]
  payments       Payment[]
  expenses       Expense[]
  adjustments    StockAdjustment[]
  auditLogs      AuditLog[]
  salariesPaid   SalaryPayment[]
  fundTransfers  FundTransfer[]
  capitalEntries CapitalEntry[]
  cheques        Cheque[]
  leaveApprovals LeaveRequest[]  @relation("LeaveApprover")
}

// ─────────────────────────── PERMISSIONS (A2) ───────────────────────────
// Data-driven RBAC. `requireRole` still guards routes today; `requirePermission`
// reads these tables so SUPER_ADMIN can retune the matrix (full editor UI in Phase 6).
// SUPER_ADMIN implicitly holds ALL permissions and is never stored/editable here.

model Permission {
  key   String @id            // "products.create"
  group String                // "Products" (for grouping in the matrix UI)
  label String                // "Create products"
  sort  Int    @default(0)    // display order within a group

  roles RolePermission[]
}

model RolePermission {
  role          Role
  permissionKey String
  permission    Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@id([role, permissionKey])
  @@index([permissionKey])
}

// ─────────────────────────── MASTER DATA ───────────────────────────

model Category {
  id        String     @id @default(cuid())
  name      String     @unique          // Cement, Iron Rods, Windows, Doors, Pipes...
  parentId  String?
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  image     String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  products  Product[]
}

model Unit {
  id         String  @id @default(cuid())
  name       String  @unique   // Bag, Kg, Ton, Piece, Foot, Sq-Ft, Bundle, Length
  shortName  String  @unique   // bag, kg, t, pc, ft, sqft, bdl, len
  // Optional conversion to a base unit (e.g. Ton -> base Kg, factor 1000)
  baseUnitId String?
  baseUnit   Unit?   @relation("UnitConversion", fields: [baseUnitId], references: [id])
  derived    Unit[]  @relation("UnitConversion")
  factor     Decimal @default(1) @db.Decimal(18, 6)

  products   Product[]
}

// STANDARD = tracks stock; SERVICE = no stock (delivery/labour/fees);
// COMBO = bundle whose sale deducts component stock (logic lands in Phase 2).
enum ProductType {
  STANDARD
  SERVICE
  COMBO
}

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique          // Lucky, Ittehad, Master, Diamond...
  image     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  products  Product[]
}

model Product {
  id             String   @id @default(cuid())
  sku            String   @unique            // auto-generated e.g. IRN-0001
  barcode        String?  @unique
  name           String                       // "Sariya 12mm Grade-60", "Lucky Cement 50kg"
  description    String?
  type           ProductType @default(STANDARD)
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id])
  unitId         String
  unit           Unit     @relation(fields: [unitId], references: [id])
  brandId        String?
  brand          Brand?   @relation(fields: [brandId], references: [id])
  costPrice      Decimal  @default(0) @db.Decimal(18, 2) // weighted avg, auto-updated on purchase
  salePrice      Decimal  @default(0) @db.Decimal(18, 2)
  wholesalePrice Decimal? @db.Decimal(18, 2)
  taxPercent     Decimal  @default(0) @db.Decimal(5, 2)
  stockQty       Decimal  @default(0) @db.Decimal(18, 3)  // cached; ledger is source of truth
  minStockLevel  Decimal  @default(0) @db.Decimal(18, 3)  // low-stock alert threshold
  // Optional physical dimensions (G10) — shown on detail, optional on invoice
  length         Decimal? @db.Decimal(12, 3)
  width          Decimal? @db.Decimal(12, 3)
  height         Decimal? @db.Decimal(12, 3)
  weight         Decimal? @db.Decimal(12, 3)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  images         ProductImage[]
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
  stockMoves     StockMovement[]
  adjustmentItems StockAdjustmentItem[]
  comboItems     ComboItem[] @relation("ComboParent")     // components of THIS combo
  usedInCombos   ComboItem[] @relation("ComboComponent")  // combos that include this product

  @@index([name])
  @@index([categoryId])
  @@index([brandId])
}

// A component line of a COMBO product. Selling the combo deducts each
// component's stock at its snapshot cost (Phase 2 sale logic).
model ComboItem {
  id                 String  @id @default(cuid())
  comboProductId     String
  comboProduct       Product @relation("ComboParent", fields: [comboProductId], references: [id], onDelete: Cascade)
  componentProductId String
  componentProduct   Product @relation("ComboComponent", fields: [componentProductId], references: [id])
  qty                Decimal @db.Decimal(18, 3)

  @@unique([comboProductId, componentProductId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  path      String              // /uploads/products/xxx.webp
  thumbPath String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)
}

// ─────────────────────────── PARTIES ───────────────────────────

model Customer {
  id             String   @id @default(cuid())
  code           String   @unique          // CUS-0001
  name           String
  phone          String?
  address        String?
  taxNumber      String?                    // CNIC / NTN
  openingBalance Decimal  @default(0) @db.Decimal(18, 2)
  balance        Decimal  @default(0) @db.Decimal(18, 2) // +ve = customer owes us (receivable)
  creditLimit    Decimal  @default(0) @db.Decimal(18, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  sales    Sale[]
  payments Payment[]
  cheques  Cheque[]

  @@index([name])
  @@index([phone])
}

model Vendor {
  id             String   @id @default(cuid())
  code           String   @unique          // VEN-0001
  name           String
  phone          String?
  address        String?
  taxNumber      String?
  bankDetails    String?
  openingBalance Decimal  @default(0) @db.Decimal(18, 2)
  balance        Decimal  @default(0) @db.Decimal(18, 2) // +ve = we owe vendor (payable)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  purchases Purchase[]
  payments  Payment[]
  cheques   Cheque[]

  @@index([name])
}

// ─────────────────────────── PURCHASING ───────────────────────────

enum PurchaseStatus {
  DRAFT
  RECEIVED
  RETURNED
  CANCELLED
}

model Purchase {
  id           String         @id @default(cuid())
  invoiceNo    String         @unique       // PUR-000123 (auto)
  vendorId     String
  vendor       Vendor         @relation(fields: [vendorId], references: [id])
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  refInvoiceNo String?                       // vendor's own bill number
  date         DateTime       @default(now())
  status       PurchaseStatus @default(RECEIVED)
  subTotal     Decimal        @default(0) @db.Decimal(18, 2)
  discount     Decimal        @default(0) @db.Decimal(18, 2)
  tax          Decimal        @default(0) @db.Decimal(18, 2)
  otherCharges Decimal        @default(0) @db.Decimal(18, 2) // freight/loading
  grandTotal   Decimal        @default(0) @db.Decimal(18, 2)
  paidAmount   Decimal        @default(0) @db.Decimal(18, 2)
  dueAmount    Decimal        @default(0) @db.Decimal(18, 2)
  notes        String?
  isReturn     Boolean        @default(false) // purchase return document
  returnOfId   String?                         // original purchase if return
  createdAt    DateTime       @default(now())

  items        PurchaseItem[]
  payments     Payment[]

  @@index([date])
  @@index([vendorId])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  qty        Decimal  @db.Decimal(18, 3)
  unitCost   Decimal  @db.Decimal(18, 2)
  discount   Decimal  @default(0) @db.Decimal(18, 2)
  total      Decimal  @db.Decimal(18, 2)
}

// ─────────────────────────── SALES / POS ───────────────────────────

enum SaleStatus {
  DRAFT       // held bill
  COMPLETED
  RETURNED
  CANCELLED
  QUOTATION
}

model Sale {
  id          String     @id @default(cuid())
  invoiceNo   String     @unique             // INV-000456 (auto)
  customerId  String?                         // null = walk-in customer
  customer    Customer?  @relation(fields: [customerId], references: [id])
  userId      String                          // cashier
  user        User       @relation(fields: [userId], references: [id])
  date        DateTime   @default(now())
  status      SaleStatus @default(COMPLETED)
  subTotal    Decimal    @default(0) @db.Decimal(18, 2)
  discount    Decimal    @default(0) @db.Decimal(18, 2)   // bill-level discount
  tax         Decimal    @default(0) @db.Decimal(18, 2)
  otherCharges Decimal   @default(0) @db.Decimal(18, 2)   // delivery/loading
  grandTotal  Decimal    @default(0) @db.Decimal(18, 2)
  paidAmount  Decimal    @default(0) @db.Decimal(18, 2)
  dueAmount   Decimal    @default(0) @db.Decimal(18, 2)   // credit (udhaar)
  totalCost   Decimal    @default(0) @db.Decimal(18, 2)   // COGS snapshot → instant profit
  profit      Decimal    @default(0) @db.Decimal(18, 2)   // grandTotal - totalCost
  notes       String?
  isReturn    Boolean    @default(false)
  returnOfId  String?                                      // original sale if return
  createdAt   DateTime   @default(now())

  items       SaleItem[]
  payments    Payment[]

  @@index([date])
  @@index([customerId])
  @@index([status])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  qty       Decimal @db.Decimal(18, 3)
  unitPrice Decimal @db.Decimal(18, 2)
  unitCost  Decimal @db.Decimal(18, 2)   // cost snapshot at time of sale
  discount  Decimal @default(0) @db.Decimal(18, 2)
  taxAmount Decimal @default(0) @db.Decimal(18, 2)
  total     Decimal @db.Decimal(18, 2)
}

// ─────────────────────────── PAYMENTS & MONEY ───────────────────────────

enum PaymentType {
  SALE_RECEIPT       // money in from a sale (at POS)
  CUSTOMER_RECEIPT   // money in against customer balance
  PURCHASE_PAYMENT   // money out for a purchase
  VENDOR_PAYMENT     // money out against vendor balance
  EXPENSE            // money out - expense
  REFUND_OUT         // refund to customer
  REFUND_IN          // refund from vendor
}

// A money account (G1). Cash drawer, bank accounts, JazzCash/EasyPaisa wallets, card.
// currentBalance is a CACHE — the AccountEntry ledger is the source of truth (every
// Payment/Transfer/Capital movement appends an entry in the same transaction).
model PaymentMethod {
  id             String         @id @default(cuid())
  name           String         @unique   // Cash, Meezan Bank, JazzCash, EasyPaisa, Card
  isCash         Boolean        @default(false)
  isActive       Boolean        @default(true)
  accountNo      String?                   // bank account / wallet number
  bankName       String?                   // Meezan, HBL…
  openingBalance Decimal        @default(0) @db.Decimal(18, 2)
  currentBalance Decimal        @default(0) @db.Decimal(18, 2) // cached = openingBalance + Σ entries
  sortOrder      Int            @default(0)
  payments       Payment[]
  entries        AccountEntry[]
  transfersOut   FundTransfer[] @relation("TransferFrom")
  transfersIn    FundTransfer[] @relation("TransferTo")
  capitalEntries CapitalEntry[]
}

// How an account balance moved. Source of truth for PaymentMethod.currentBalance.
enum AccountEntryType {
  PAYMENT      // linked to a Payment (sale/purchase/receipt/vendor/expense/refund)
  TRANSFER_IN
  TRANSFER_OUT
  CAPITAL_IN   // owner deposited capital
  DRAWING      // owner withdrew (not an expense — hits equity)
  OPENING      // opening balance seed
}

// Per-account money ledger. `amount` is SIGNED (+in / −out); `balance` is the
// running total after this entry. currentBalance cache == last balance.
model AccountEntry {
  id        String           @id @default(cuid())
  accountId String
  account   PaymentMethod    @relation(fields: [accountId], references: [id])
  type      AccountEntryType
  amount    Decimal          @db.Decimal(18, 2)  // signed
  balance   Decimal          @db.Decimal(18, 2)  // running balance after this entry
  refType   String?                              // "Payment" | "FundTransfer" | "CapitalEntry"
  refId     String?
  date      DateTime         @default(now())
  notes     String?
  createdAt DateTime         @default(now())

  @@index([accountId, date])
}

// Money moved between two accounts (e.g. cash drawer → bank deposit). Creates a
// paired TRANSFER_OUT + TRANSFER_IN in the same transaction. No P&L effect.
model FundTransfer {
  id            String        @id @default(cuid())
  refNo         String        @unique   // TRN-000001
  fromAccountId String
  fromAccount   PaymentMethod @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccountId   String
  toAccount     PaymentMethod @relation("TransferTo", fields: [toAccountId], references: [id])
  amount        Decimal       @db.Decimal(18, 2)
  date          DateTime      @default(now())
  notes         String?
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  createdAt     DateTime      @default(now())

  @@index([date])
}

// Owner capital in / drawings out. Affects the Balance Sheet (equity), NOT P&L.
enum CapitalDirection {
  CAPITAL_IN
  DRAWING
}

model CapitalEntry {
  id        String           @id @default(cuid())
  refNo     String           @unique   // CAP-000001 / DRW-000001
  direction CapitalDirection
  accountId String
  account   PaymentMethod    @relation(fields: [accountId], references: [id])
  amount    Decimal          @db.Decimal(18, 2)
  date      DateTime         @default(now())
  notes     String?
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())

  @@index([date])
}

model Payment {
  id         String        @id @default(cuid())
  refNo      String        @unique            // PAY-000789 (auto)
  type       PaymentType
  methodId   String
  method     PaymentMethod @relation(fields: [methodId], references: [id])
  amount     Decimal       @db.Decimal(18, 2)
  date       DateTime      @default(now())
  customerId String?
  customer   Customer?     @relation(fields: [customerId], references: [id])
  vendorId   String?
  vendor     Vendor?       @relation(fields: [vendorId], references: [id])
  saleId     String?
  sale       Sale?         @relation(fields: [saleId], references: [id])
  purchaseId String?
  purchase   Purchase?     @relation(fields: [purchaseId], references: [id])
  expenseId  String?       @unique
  expense    Expense?      @relation(fields: [expenseId], references: [id])
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  notes      String?
  createdAt  DateTime      @default(now())

  @@index([date])
  @@index([type])
}

// ─────────────────────────── CHEQUES (F1) ───────────────────────────
// Post-dated cheque tracking. A RECEIVED cheque settles the customer's udhaar and
// sits in a "Cheques in Hand" holding account (an asset) until it CLEARS into a bank
// account; a BOUNCE cleanly reverses the receipt (customer owes again). ISSUED cheques
// mirror this against a post-dated-cheques holding account for vendors.
enum ChequeDirection {
  RECEIVED // customer gave us a cheque
  ISSUED   // we gave a vendor a cheque
}

enum ChequeStatus {
  PENDING   // not yet cleared — money is promised, not real cash
  CLEARED   // cleared into/out of a bank account
  BOUNCED   // returned unpaid — receipt reversed
  CANCELLED // torn up / replaced before clearing
}

model Cheque {
  id               String          @id @default(cuid())
  refNo            String          @unique // CHQ-000001
  direction        ChequeDirection
  customerId       String?
  customer         Customer?       @relation(fields: [customerId], references: [id])
  vendorId         String?
  vendor           Vendor?         @relation(fields: [vendorId], references: [id])
  bankName         String // the drawer's bank printed on the cheque
  chequeNo         String
  amount           Decimal         @db.Decimal(18, 2)
  chequeDate       DateTime // the date written on the cheque (when it can be banked)
  status           ChequeStatus    @default(PENDING)
  holdingAccountId String // "Cheques in Hand" (received) / "Post-dated Cheques" (issued) — where it sits while PENDING
  settledAccountId String? // the real bank account it cleared into/out of
  receiptPaymentId String? // the Payment created on receive/issue (used to reverse on bounce)
  clearedAt        DateTime?
  notes            String?
  userId           String
  user             User            @relation(fields: [userId], references: [id])
  createdAt        DateTime        @default(now())

  @@index([status])
  @@index([chequeDate])
}

model ExpenseCategory {
  id       String    @id @default(cuid())
  name     String    @unique   // Rent, Salaries, Electricity, Transport, Tea/Misc
  expenses Expense[]
}

model Expense {
  id         String          @id @default(cuid())
  refNo      String          @unique          // EXP-000012
  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id])
  amount     Decimal         @db.Decimal(18, 2)
  date       DateTime        @default(now())
  notes      String?
  userId     String
  user       User            @relation(fields: [userId], references: [id])
  payment    Payment?
  createdAt  DateTime        @default(now())

  @@index([date])
}

// ─────────────────────────── STOCK LEDGER ───────────────────────────

enum StockMoveType {
  PURCHASE
  PURCHASE_RETURN
  SALE
  SALE_RETURN
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  DAMAGE
  OPENING
}

// Source of truth for stock. Product.stockQty is a cached sum.
model StockMovement {
  id        String        @id @default(cuid())
  productId String
  product   Product       @relation(fields: [productId], references: [id])
  type      StockMoveType
  qty       Decimal       @db.Decimal(18, 3)  // +in / -out
  unitCost  Decimal?      @db.Decimal(18, 2)
  refType   String?                            // "SALE" | "PURCHASE" | "ADJUSTMENT"
  refId     String?                            // id of the sale/purchase/adjustment
  balance   Decimal       @db.Decimal(18, 3)   // running stock after this move
  date      DateTime      @default(now())
  notes     String?

  @@index([productId, date])
}

model StockAdjustment {
  id        String                @id @default(cuid())
  refNo     String                @unique      // ADJ-000005
  reason    String                              // Damage, Count correction, Theft...
  date      DateTime              @default(now())
  userId    String
  user      User                  @relation(fields: [userId], references: [id])
  items     StockAdjustmentItem[]
  createdAt DateTime              @default(now())
}

model StockAdjustmentItem {
  id           String          @id @default(cuid())
  adjustmentId String
  adjustment   StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  productId    String
  product      Product         @relation(fields: [productId], references: [id])
  qtyChange    Decimal         @db.Decimal(18, 3) // +5 or -3
}


// ─────────────────────────── EMPLOYEES & SALARIES ───────────────────────────

model Employee {
  id          String   @id @default(cuid())
  code        String   @unique          // EMP-0001
  name        String
  phone       String?
  cnic        String?                    // national ID
  address     String?
  designation String?                    // Salesman, Loader, Accountant, Driver...
  photo       String?                    // /uploads/employees/xxx.webp
  joinDate    DateTime @default(now())
  baseSalary  Decimal  @default(0) @db.Decimal(18, 2)   // monthly
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  shiftId      String?
  shift        Shift?      @relation(fields: [shiftId], references: [id])

  salaries      SalaryPayment[]
  leaveRequests LeaveRequest[]
}

// ─────────────────────────── HR EXTENSIONS (G6, lightweight) ───────────────────────────

model Department {
  id        String     @id @default(cuid())
  name      String     @unique          // Sales, Warehouse, Accounts, Delivery
  createdAt DateTime   @default(now())
  employees Employee[]
}

model Shift {
  id        String     @id @default(cuid())
  name      String     @unique          // Morning, Evening
  startTime String                       // "09:00"
  endTime   String                       // "18:00"
  employees Employee[]
}

enum LeaveType {
  PAID
  UNPAID
  SICK
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveRequest {
  id         String      @id @default(cuid())
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fromDate   DateTime
  toDate     DateTime
  days       Int         @default(1)
  type       LeaveType   @default(UNPAID)
  status     LeaveStatus @default(PENDING)
  reason     String?
  approverId String?
  approver   User?       @relation("LeaveApprover", fields: [approverId], references: [id])
  createdAt  DateTime    @default(now())

  @@index([employeeId])
}

model Holiday {
  id   String   @id @default(cuid())
  date DateTime @unique
  name String
}

// Paying a salary also creates an Expense (category "Salaries") in the same
// transaction so P&L stays correct automatically.
model SalaryPayment {
  id         String   @id @default(cuid())
  refNo      String   @unique            // SAL-000012
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  month      String                       // "2026-06" — the salary period
  baseAmount Decimal  @db.Decimal(18, 2)
  bonus      Decimal  @default(0) @db.Decimal(18, 2)
  deduction  Decimal  @default(0) @db.Decimal(18, 2)   // advances, penalties
  netPaid    Decimal  @db.Decimal(18, 2)                // base + bonus - deduction
  date       DateTime @default(now())
  notes      String?
  userId     String                        // who paid
  user       User     @relation(fields: [userId], references: [id])
  expenseId  String?  @unique              // linked auto-created Expense row
  createdAt  DateTime @default(now())

  @@unique([employeeId, month])            // one salary per employee per month
  @@index([month])
}

// ─────────────────────────── NOTIFICATIONS & MESSAGING ───────────────────────────

enum NotificationType {
  LOW_STOCK        // product fell below minStockLevel
  DEBT_REMINDER    // customer receivable pending too long
  PAYABLE_REMINDER // vendor payment due
  CREDIT_LIMIT     // customer crossed credit limit
  CHEQUE_DUE       // a pending cheque is due to clear on/before today
  SYSTEM           // backups, errors, announcements
}

// In-app notification bell (generated by server-side checks / cron)
model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  entity    String?           // "Product" | "Customer" | "Vendor"
  entityId  String?
  isRead    Boolean          @default(false)
  userId    String?           // null = broadcast to all users
  createdAt DateTime         @default(now())

  @@index([isRead, createdAt])
}

enum MessageChannel {
  WHATSAPP
  EMAIL
}

enum MessageStatus {
  QUEUED
  SENT
  FAILED
  CLICKED    // for wa.me link mode: link was generated/opened
}

// Every WhatsApp/Email we send (sale receipts, purchase confirmations,
// debt reminders, statements) is logged here for the audit trail.
model MessageLog {
  id        String         @id @default(cuid())
  channel   MessageChannel
  recipient String                         // phone or email
  template  String                         // SALE_RECEIPT, PURCHASE_CONFIRM, DEBT_REMINDER, STATEMENT
  refType   String?                        // "Sale" | "Purchase" | "Customer"
  refId     String?
  status    MessageStatus  @default(QUEUED)
  error     String?
  createdAt DateTime       @default(now())

  @@index([createdAt])
}

// ─────────────────────────── SYSTEM ───────────────────────────

model Setting {
  key   String @id      // shop_name, shop_logo, address, phone, tax_percent, currency, invoice_footer, receipt_size
  value String
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String            // LOGIN, CREATE_SALE, DELETE_PRODUCT, UPDATE_SETTING...
  entity    String?           // Sale, Product...
  entityId  String?
  details   String?           // JSON string of changes
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Counter {
  key   String @id  // "sale", "purchase", "payment", "customer", "vendor", "expense", "adjustment", "sku", "employee", "salary", "transfer", "capital", "drawing"
  value Int    @default(0)
}
